# Copy to .env and adjust as needed. NEVER commit the real .env file.

# SQLite database path (relative to project root)
DB_PATH=data/vpp.db

# Path to the trained PPO model directory/zip used by the API loop
MODEL_PATH=models/checkpoints/best_model

# APScheduler control-loop interval in minutes
LOOP_INTERVAL_MINUTES=30

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
